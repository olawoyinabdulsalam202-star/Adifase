# Server
PORT=4000
NODE_ENV=development

# Frontend origin allowed by CORS (comma-separate multiple origins)
FRONTEND_URL=http://localhost:5173

# Admin credentials — checked server-side only, never from the DB
ADMIN_EMAIL=admin@adifase97.org
ADMIN_PASSWORD=StrongPasswordHere

# JWT secrets — use long random strings in production
JWT_VOTER_SECRET=change_me_voter_secret
JWT_ADMIN_SECRET=change_me_admin_secret

# Token lifetimes
VOTER_TOKEN_EXPIRES_IN=4h
ADMIN_TOKEN_EXPIRES_IN=2h

# SQLite file path (swap this layer for Postgres in production — see README)
DATABASE_FILE=./data/adifase.db

# Where uploaded photos are stored locally (dev fallback; use S3/Cloudinary in prod)
UPLOAD_DIR=./uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:4000/uploads
