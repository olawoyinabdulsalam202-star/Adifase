# Copy this file to .env and fill in real values. Never commit .env.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

VITE_ADMIN_EMAIL=admin@adifase97.org
VITE_ADMIN_PASSWORD=ChangeThisStrongPassword123!

# Set this once the real backend exists. Leave blank to keep using localStorage.
# See src/lib/api.js and src/lib/db.js for where this plugs in.
VITE_API_BASE_URL=
